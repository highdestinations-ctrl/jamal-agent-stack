{
  "name": "jamal-agent-stack",
  "version": "0.0.1",
  "description": "Production-minded multi-service agent stack",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=9.0.0"
  },
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "typecheck": "pnpm -r typecheck",
    "demo": "tsx scripts/demo.ts"
  },
  "devDependencies": {
    "tsx": "^4.7.0"
  }
}
